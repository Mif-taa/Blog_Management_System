# ========================
# Environment Variables
# ========================

# JWT Secret Key — change this in production!
JWT_SECRET=my_super_secret_jwt_key_change_in_production

# JWT Token Expiry
JWT_EXPIRES_IN=7d

# Server Port
PORT=3000

# ── Database ──────────────────────────────────────────────────
# Leave DATABASE_URL blank to use local JSON file storage.
# On Render: set this to your PostgreSQL connection string, e.g.:
# DATABASE_URL=postgresql://user:pass@host/dbname
DATABASE_URL=
